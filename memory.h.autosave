#ifndef MEMORY_H
#define MEMORY_H

class Memory
{
public:
    
    //memory stores 2^15 addresses, but 4 address per l
    int memory[8192][2];
    int cache[8][7];

    int fClock;
    int mClock;

    int prevWriteAddr;
    int prevWriteStage;

    Memory();
    void writeMemory(int address, int data, int pipelineStage);
    int readMemory(int address, int pipelineStage);
    int viewMemory(int address);

};

#endif // MEMORY_H

